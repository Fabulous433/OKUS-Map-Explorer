# Local development environment
DATABASE_URL=postgresql://okus_dev:okus_dev@localhost:55432/okus_map_explorer
SESSION_SECRET=change-me-local-dev
PORT=5000
ENABLE_STARTUP_SEED=true
ATTACHMENTS_STORAGE_ROOT=./uploads
SLOW_QUERY_MS=300
AUTH_LOGIN_RATE_LIMIT_WINDOW_MS=60000
AUTH_LOGIN_RATE_LIMIT_MAX_REQUESTS=40
AUTH_LOGIN_LOCKOUT_THRESHOLD=5
AUTH_LOGIN_LOCKOUT_MS=300000
BACKUP_DIR=backups
BACKUP_ENV=local
BACKUP_CONTAINER=okus-postgres
BACKUP_DB_NAME=okus_map_explorer
BACKUP_DB_USER=okus_dev
BACKUP_RETENTION_DAYS_DAILY=35
BACKUP_RETENTION_WEEKS_WEEKLY=12
BACKUP_RETENTION_MONTHS_MONTHLY=12
RESTORE_DRILL_DB_NAME=okus_restore_drill
REPORT_EXPORT_BASE_URL=http://127.0.0.1:5000
REPORT_EXPORT_OUTPUT_DIR=reports
REPORT_EXPORT_USERNAME=admin
REPORT_EXPORT_PASSWORD=admin123
REPORT_EXPORT_GENERATED_BY=system
REPORT_EXPORT_RETRY_ATTEMPTS=3
REPORT_EXPORT_RETRY_DELAY_MS=300000
REPORT_EXPORT_TIMEOUT_MS=600000
SMOKE_BASE_URL=http://127.0.0.1:5000
SMOKE_USERNAME=admin
SMOKE_PASSWORD=admin123
SMOKE_TIMEOUT_MS=30000
POST_LAUNCH_BASE_URL=http://127.0.0.1:5000
POST_LAUNCH_OUTPUT_DIR=reports
POST_LAUNCH_USERNAME=admin
POST_LAUNCH_PASSWORD=admin123
POST_LAUNCH_TIMEOUT_MS=30000
POST_LAUNCH_GENERATED_BY=system
